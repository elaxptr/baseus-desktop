{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "baseus-app",
  "version": "0.2.1",
  "identifier": "com.baseus.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Baseus Desktop",
        "width": 480,
        "height": 620,
        "resizable": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/elaxptr/baseus-desktop/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM5NzZFNEMyRkM5M0UyNTUKUldSVjRwUDh3dVIyT2Z2VTdWVUZaSmtLTC9TUmxTRktCbjhUb0loeGxUbjlHRll0NUtVTGY0c0UK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
